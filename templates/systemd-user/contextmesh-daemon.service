[Unit]
Description=Context Mesh Daemon (user)
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/.local/share/contextmesh/scripts
Environment=CONTEXT_MESH_ENABLE_REMOTE_SYNC=0
ExecStart=/usr/bin/env python3 %h/.local/share/contextmesh/scripts/context_daemon.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
