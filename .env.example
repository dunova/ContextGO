# ContextGO - Environment Variables
# Copy this file to .env and adjust values for your setup.

# --- Required ---
# Optional API keys for archived compatibility / future extensions
GEMINI_API_KEY=

# --- Optional: Remote sync ---
# CONTEXTGO_REMOTE_URL=http://<host>:8090/api/v1
# CONTEXTGO_ENABLE_REMOTE_MEMORY_HTTP=0
# CONTEXTGO_EXPORT_HTTP_TIMEOUT_SEC=30
# CONTEXTGO_PENDING_HTTP_TIMEOUT_SEC=15
# CONTEXTGO_PENDING_RETRY_INTERVAL_SEC=60

# --- Optional: Unified Context Storage ---
# CONTEXTGO_STORAGE_ROOT=$HOME/.contextgo
# UNIFIED_CONTEXT_STORAGE_ROOT=$HOME/.contextgo
# MEMORY_INDEX_DB_PATH=$UNIFIED_CONTEXT_STORAGE_ROOT/index/memory_index.db
# CONTEXTGO_SESSION_INDEX_DB_PATH=$CONTEXTGO_STORAGE_ROOT/index/session_index.db

# --- Optional: Memory Viewer (P2) ---
# CONTEXTGO_VIEWER_HOST=127.0.0.1
# CONTEXTGO_VIEWER_PORT=37677
# CONTEXTGO_VIEWER_TOKEN=
# CONTEXT_VIEWER_HOST=127.0.0.1
# CONTEXT_VIEWER_PORT=37677
# CONTEXT_VIEWER_TOKEN=
# CONTEXT_VIEWER_MAX_POST_BYTES=1048576
# CONTEXT_VIEWER_MAX_BATCH_IDS=500

# --- Optional: Daemon tuning ---
# CONTEXTGO_ENABLE_SHELL_MONITOR=0
# CONTEXTGO_ENABLE_CLAUDE_HISTORY_MONITOR=1
# CONTEXTGO_ENABLE_CODEX_HISTORY_MONITOR=1
# CONTEXTGO_ENABLE_OPENCODE_MONITOR=0
# CONTEXTGO_ENABLE_KILO_MONITOR=0
# CONTEXTGO_ENABLE_REMOTE_SYNC=0
# CONTEXTGO_ENABLE_CODEX_SESSION_MONITOR=1
# CONTEXTGO_ENABLE_CLAUDE_TRANSCRIPTS_MONITOR=1
# CONTEXTGO_ENABLE_ANTIGRAVITY_MONITOR=1
# CONTEXTGO_POLL_INTERVAL_SEC=180
# CONTEXTGO_FAST_POLL_INTERVAL_SEC=20
# CONTEXTGO_IDLE_SLEEP_CAP_SEC=600
# CONTEXTGO_HEARTBEAT_INTERVAL_SEC=600
# CONTEXTGO_IDLE_TIMEOUT_SEC=300
# CONTEXTGO_INDEX_SYNC_MIN_INTERVAL_SEC=20
# CONTEXTGO_LOOP_JITTER_SEC=0.7
# CONTEXTGO_ERROR_BACKOFF_MAX_SEC=30
# CONTEXTGO_CYCLE_BUDGET_SEC=8
# CONTEXTGO_NIGHT_POLL_INTERVAL_SEC=900
# CONTEXTGO_MAX_TRACKED_SESSIONS=240
# CONTEXTGO_MAX_FILE_CURSORS=800
# CONTEXTGO_SESSION_TTL_SEC=7200
# CONTEXTGO_MAX_MESSAGES_PER_SESSION=500
# CONTEXTGO_CODEX_SESSION_SCAN_INTERVAL_SEC=300
# CONTEXTGO_CLAUDE_TRANSCRIPT_SCAN_INTERVAL_SEC=300
# CONTEXTGO_ANTIGRAVITY_SCAN_INTERVAL_SEC=300
# CONTEXTGO_MAX_CODEX_SESSION_FILES_PER_SCAN=160
# CONTEXTGO_MAX_CLAUDE_TRANSCRIPT_FILES_PER_POLL=120
# CONTEXTGO_MAX_ANTIGRAVITY_DIRS_PER_SCAN=80
# CONTEXTGO_SUSPEND_ANTIGRAVITY_WHEN_BUSY=1
# CONTEXTGO_ANTIGRAVITY_BUSY_LS_THRESHOLD=2
# CONTEXTGO_ANTIGRAVITY_INGEST_MODE=final_only
# CONTEXTGO_ANTIGRAVITY_QUIET_SEC=240
# CONTEXTGO_ANTIGRAVITY_MIN_DOC_BYTES=500
# CONTEXTGO_EXPORT_HTTP_TIMEOUT_SEC=30
# CONTEXTGO_PENDING_HTTP_TIMEOUT_SEC=15


# --- Optional: Deploy ---
# CONTEXTGO_INSTALL_ROOT=$HOME/.local/share/contextgo
# CGO_INSTALL_ROOT=$HOME/.local/share/contextgo
# PATCH_LAUNCHD=1
# RELOAD_LAUNCHD=1

# --- Optional: Legacy compatibility shim ---
# ONECONTEXT_BIN=
# ONECONTEXT_DB_PATH=
# ALLOW_NOOP_MCP=0

# --- Optional: LiteLLM ---
# LITELLM_LOCAL_MODEL_COST_MAP=True
